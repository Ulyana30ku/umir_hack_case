{
  "manifest_version": 3,
  "name": "Chiki AI",
  "description": "Управляйте браузером через естественный язык",
  "version": "1.0.0",
  "icons": {
    "16": "icons/logo_16.png",
    "32": "icons/logo_32.png",
    "48": "icons/logo_48.png",
    "128": "icons/logo_128.png"
  },
  "action": {
    "default_title": "Chiki AI",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/logo_16.png",
      "32": "icons/logo_32.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:8000/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}